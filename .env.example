# ============================================================
# AI for China Legal — Environment Variables
# Copy this file to .env and fill in actual values.
# ============================================================

# --- 裁判文书网 (wenshu) ---
WENSHU_API_URL=https://wenshu.court.gov.cn/api
WENSHU_API_KEY=

# --- 企业信用信息公示系统 (gsxt) ---
GSXT_API_URL=https://www.gsxt.gov.cn/api
GSXT_API_KEY=

# --- 国家法律法规数据库 (law-database) ---
LAW_DB_API_URL=https://flk.npc.gov.cn/api
LAW_DB_API_KEY=
LAW_DB_TIMEOUT_MS=30000
LAW_DB_MAX_RETRIES=3
LAW_DB_CACHE_TTL_SECONDS=86400

# --- 企业微信/钉钉通知 (wechat-notify) ---
WECHAT_CORP_ID=
WECHAT_AGENT_ID=
WECHAT_SECRET=

# --- 商标查询 (trademark) ---
TRADEMARK_API_URL=https://sbj.cnipa.gov.cn/api
TRADEMARK_API_KEY=

# --- 专利查询 (patent) ---
PATENT_API_URL=https://pss-system.cnipa.gov.cn/api
PATENT_API_KEY=

# --- 案件管理系统 ---
CASE_MANAGEMENT_API_URL=
CASE_MANAGEMENT_API_KEY=

# --- 通知渠道 ---
NOTIFICATION_CHANNEL=wechat

