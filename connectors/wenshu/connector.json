{
  "name": "wenshu",
  "version": "1.0.0",
  "description": "中国裁判文书网 MCP 连接器，提供裁判文书搜索、详情查询和统计分析功能",
  "displayName": "裁判文书网连接器",
  "category": "legal-data",
  "dataSources": [
    {
      "name": "中国裁判文书网",
      "url": "https://wenshu.court.gov.cn",
      "type": "rest-api",
      "description": "最高人民法院主办的裁判文书公开平台"
    }
  ],
  "authentication": {
    "type": "api-key",
    "headerName": "Authorization",
    "headerPrefix": "Bearer",
    "envVar": "WENSHU_API_KEY"
  },
  "env": {
    "WENSHU_API_URL": {
      "description": "裁判文书网 API 基础地址",
      "default": "https://wenshu.court.gov.cn/api",
      "required": true
    },
    "WENSHU_API_KEY": {
      "description": "裁判文书网 API 密钥",
      "required": true,
      "secret": true
    },
    "WENSHU_TIMEOUT_MS": {
      "description": "请求超时时间（毫秒）",
      "default": "30000",
      "required": false
    },
    "WENSHU_MAX_RETRIES": {
      "description": "最大重试次数",
      "default": "3",
      "required": false
    }
  },
  "tools": [
    {
      "name": "search_cases",
      "description": "根据关键词、案由、法院、日期范围等条件搜索裁判文书",
      "inputSchema": {
        "type": "object",
        "properties": {
          "keyword": {
            "type": "string",
            "description": "搜索关键词"
          },
          "causeOfAction": {
            "type": "string",
            "description": "案由分类（如：买卖合同纠纷、劳动争议）"
          },
          "courtName": {
            "type": "string",
            "description": "法院名称"
          },
          "courtLevel": {
            "type": "string",
            "enum": ["基层", "中级", "高级", "最高"],
            "description": "法院层级"
          },
          "dateRange": {
            "type": "object",
            "properties": {
              "start": { "type": "string", "format": "date" },
              "end": { "type": "string", "format": "date" }
            },
            "description": "裁判日期范围"
          },
          "caseType": {
            "type": "string",
            "enum": ["民事", "刑事", "行政", "执行", "其他"],
            "description": "案件类型"
          },
          "page": {
            "type": "integer",
            "default": 1,
            "description": "页码"
          },
          "pageSize": {
            "type": "integer",
            "default": 20,
            "description": "每页数量"
          }
        },
        "required": []
      }
    },
    {
      "name": "get_case_detail",
      "description": "根据案号获取裁判文书详情",
      "inputSchema": {
        "type": "object",
        "properties": {
          "caseNumber": {
            "type": "string",
            "description": "案号（如：(2026)京01民初1234号）"
          }
        },
        "required": ["caseNumber"]
      }
    },
    {
      "name": "get_case_statistics",
      "description": "获取案件统计数据（裁判趋势、地域分布等）",
      "inputSchema": {
        "type": "object",
        "properties": {
          "causeOfAction": {
            "type": "string",
            "description": "案由分类"
          },
          "courtName": {
            "type": "string",
            "description": "法院名称"
          },
          "timeRange": {
            "type": "string",
            "enum": ["近1月", "近3月", "近6月", "近1年", "近3年"],
            "description": "统计时间范围"
          },
          "groupBy": {
            "type": "string",
            "enum": ["月份", "法院", "案由", "地域"],
            "description": "分组维度"
          }
        },
        "required": ["causeOfAction"]
      }
    }
  ],
  "rateLimit": {
    "requestsPerSecond": 1,
    "requestsPerDay": 1000,
    "maxConcurrent": 2
  },
  "retry": {
    "maxAttempts": 3,
    "initialDelayMs": 2000,
    "maxDelayMs": 30000,
    "backoffMultiplier": 2.5,
    "retryableStatusCodes": [429, 502, 503, 504]
  },
  "healthCheck": {
    "endpoint": "/health",
    "intervalSeconds": 300
  }
}
